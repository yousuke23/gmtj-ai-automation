# Copy to .env and fill. Never commit .env
#
# Open WebUI（deploy/docker-compose.yml）用
WEBUI_SECRET_KEY=change-me-long-random-string
#
# 利用するモデルプロバイダに合わせて設定（未使用は空のままで可）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# VECTOR_DB_URL=
#
# --- 全世界向けステージング（docker-compose.worldwide-staging.yml）用 ---
# DNS が VPS を向けたあとに設定。手順: deploy/WORLDWIDE-STAGING.md
# GMTJ_PUBLIC_DOMAIN=chat.staging.example.com
# ACME_EMAIL=ops@example.com
